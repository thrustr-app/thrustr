{
  "languages": {
    "SQL": {
      "formatter": {
        "external": {
          "command": "sql-formatter",
          "arguments": ["--language", "sqlite"],
        },
      },
    },
  },
  "hard_tabs": false,
  "formatter": "auto",
  "remove_trailing_whitespace_on_save": true,
  "ensure_final_newline_on_save": true,
  "file_scan_exclusions": ["**/.git", "**/.DS_Store", "**/Thumbs.db"],
  "read_only_files": [
    "**/.rustup/**",
    "**/.cargo/registry/**",
    "**/.cargo/git/**",
    "**/*.lock",
  ],
}
